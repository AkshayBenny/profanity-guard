{
	"name": "profanity-guard",
	"version": "1.1.5",
	"description": "A blazingly fast, multi-language profanity filter (English, French, Hindi, Russian, Mandarin) for React, Next.js, and Node.js.",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"scripts": {
		"test": "vitest run",
		"test:watch": "vitest",
		"build": "tsc",
		"prepublishOnly": "npm run build",
		"ship-it": "npm version patch && npm run build && npm publish"
	},
	"files": [
		"dist"
	],
	"keywords": [
		"profanity",
		"filter",
		"bad words",
		"censor",
		"moderation",
		"multilingual",
		"i18n",
		"internationalization",
		"english",
		"french",
		"hindi",
		"russian",
		"mandarin",
		"chinese",
		"react",
		"nextjs",
		"typescript"
	],
	"author": "Akshay Benny",
	"homepage": "https://github.com/AkshayBenny/profanity-guard#readme",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/AkshayBenny/profanity-guard.git"
	},
	"bugs": {
		"url": "https://github.com/AkshayBenny/profanity-guard/issues"
	},
	"license": "MIT",
	"devDependencies": {
		"@types/node": "^25.6.0",
		"typescript": "^6.0.3",
		"vitest": "^4.1.5"
	}
}
