{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "composite": true, // Required for project references
    "declaration": true,
    "declarationMap": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "ignoreDeprecations": "6.0"
  },
  "files": [],
  "references": [
    { "path": "packages/core" },
    { "path": "packages/express" },
    { "path": "packages/react" },
    { "path": "packages/next" }
  ]
}