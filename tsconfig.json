{
	"compilerOptions": {
		"target": "ES2018",
		"module": "CommonJS",
		"lib": ["ES2018", "DOM"],
		"declaration": true,
		"rootDir": "./src",
		"outDir": "./dist",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true
	},
	"include": ["src/**/*"],
	"exclude": ["node_modules", "dist"]
}
