{
	"compilerOptions": {
		"ignoreDeprecations": "6.0",
		"baseUrl": ".",
		"outDir": "dist",
		"rootDir": "src",
		"declaration": true,
		"module": "NodeNext",
		"target": "ESNext",
		"declarationMap": true,
		"moduleResolution": "NodeNext",
		"skipLibCheck": true,
		"esModuleInterop": true
	},
	"include": ["src/**/*"],
	"exclude": ["node_modules", "src/**/*.test.ts"]
}
